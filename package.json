{
  "author": {
    "email": "milev.stefan@gmail.com",
    "name": "Delemangi",
    "url": "https://delemangi.com"
  },
  "bugs": {
    "url": "https://github.com/Delemangi/eslint-config-imperium/issues"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/compat": "^2.0.5",
    "@next/eslint-plugin-next": "^16.2.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tanstack/eslint-plugin-query": "^5.99.2",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2",
    "vue-eslint-parser": "^10.4.0"
  },
  "description": "Comprehensive ESLint configuration",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "react": "^19.2.5",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "files": [
    "!**/*.test.*",
    "!test",
    "lib"
  ],
  "homepage": "https://github.com/Delemangi/eslint-config-imperium",
  "keywords": [
    "eslint",
    "eslint-config",
    "imperium",
    "typescript"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "name": "eslint-config-imperium",
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    },
    "eslint-plugin-promise": {
      "eslint": "$eslint"
    },
    "eslint-plugin-solid": {
      "eslint": "$eslint"
    }
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Delemangi/eslint-config-imperium.git"
  },
  "scripts": {
    "build": "rimraf lib && tsc",
    "check": "tsc --noEmit",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "format": "eslint --ignore-pattern \"**/test/cases/*\" --fix .",
    "format:dev": "npm run build && npm run format",
    "lint": "eslint . --ignore-pattern \"**/test/cases/*\" --no-warn-ignored --cache",
    "lint:dev": "npm run build && npm run lint",
    "package": "npm run build && npm pack",
    "prepare": "husky",
    "release": "npm run build && semantic-release",
    "release:dry": "npm run build && npm run release -- --dry-run",
    "test": "vitest run --exclude lib"
  },
  "type": "module",
  "types": "lib/index.d.ts",
  "version": "0.0.0"
}
